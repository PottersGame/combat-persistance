{
	"schemaVersion": 1,
	"id": "combatpersistence",
	"version": "${version}",
	"name": "Combat Persistence",
	"description": "Prevents combat logging by spawning a persistent NPC (Mannequin) when a player disconnects in combat.",
	"authors": [
		"PottersGame"
	],
	"contact": {
		"sources": "https://github.com/PottersGame/combat-persistance"
	},
	"license": "GPL-3.0",
	"icon": "assets/combatpersistence/icon.png",
	"environment": "server",
	"entrypoints": {
		"main": [
			"com.pottersgame.Combatpersistence"
		]
	},
	"mixins": [
		"combatpersistence.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}